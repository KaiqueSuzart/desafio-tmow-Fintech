# Copie para .env e preencha com a sua chave.
# NUNCA commitar chaves reais neste ficheiro.
# Obtenha a sua chave em https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Opcional: timeout Playwright em ms (30 000–300 000; predefinido 120 000)
# PLAYWRIGHT_NAV_TIMEOUT_MS=120000

# (Obsoleto) EPUBLICA_DEFAULT_MAX_PAGES — já não é usado; use «Máx. páginas» / «Buscar todas» na UI.
